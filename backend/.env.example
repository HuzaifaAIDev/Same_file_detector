# Copy this file to .env and fill in real values. Never commit .env.

# ---- General ----
APP_NAME=Universal File Comparer
ENVIRONMENT=development
DEBUG=true

# ---- Server ----
HOST=0.0.0.0
PORT=20285
FRONTEND_URL=http://localhost:20285

# ---- Security ----
# Generate a strong secret, e.g.: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=changeme-generate-a-real-secret-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ---- CORS ----
CORS_ORIGINS=["http://localhost:20285","http://127.0.0.1:20285"]

# ---- Database ----
# SQLite (default, good for development):
# DATABASE_URL=sqlite:///./app_data.db
# PostgreSQL (production):
DATABASE_URL=postgresql+psycopg2://user:password@localhost:5432/file_comparer

# ---- Uploads ----
MAX_UPLOAD_SIZE_MB=25
MAX_FILES_PER_REQUEST=20

# ---- Legacy path-based compare (disabled by default; security risk) ----
ENABLE_LOCAL_PATH_COMPARE=false

# ---- Rate limiting ----
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW_SECONDS=60

# ---- OCR ----
TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe

# =====================================================================
# Email OTP (registration + forgot password)
# =====================================================================
# Leave SMTP_HOST blank to run without a real mail server: OTP codes are
# written to backend/logs/app.log instead of being emailed. Set real
# values here to actually send mail (e.g. Gmail SMTP, SendGrid, SES).
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=no-reply@example.com
SMTP_USE_TLS=true

OTP_LENGTH=6
OTP_EXPIRE_MINUTES=5
OTP_RESEND_SECONDS=60
OTP_MAX_ATTEMPTS=5

# =====================================================================
# Auto-provisioned admin account (created on startup if missing)
# =====================================================================
ADMIN_FIRST_NAME=System
ADMIN_LAST_NAME=Administrator
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=Admin@123
ADMIN_ROLE=admin

# =====================================================================
# Auto-provisioned test users (created on startup if missing)
# All test users share one password. Leave a user's fields blank to
# skip creating that user.
# =====================================================================
TEST_USERS_PASSWORD=Testing@123

TEST_USER_1_FIRST_NAME=Ali
TEST_USER_1_LAST_NAME=Khan
TEST_USER_1_USERNAME=ali
TEST_USER_1_EMAIL=ali@example.com

TEST_USER_2_FIRST_NAME=Ahmed
TEST_USER_2_LAST_NAME=Raza
TEST_USER_2_USERNAME=ahmed
TEST_USER_2_EMAIL=ahmed@example.com

TEST_USER_3_FIRST_NAME=Sara
TEST_USER_3_LAST_NAME=Iqbal
TEST_USER_3_USERNAME=sara
TEST_USER_3_EMAIL=sara@example.com

TEST_USER_4_FIRST_NAME=Fatima
TEST_USER_4_LAST_NAME=Noor
TEST_USER_4_USERNAME=fatima
TEST_USER_4_EMAIL=fatima@example.com

TEST_USER_5_FIRST_NAME=Huzaifa
TEST_USER_5_LAST_NAME=Developer
TEST_USER_5_USERNAME=huzaifa
TEST_USER_5_EMAIL=huzaifa@example.com
